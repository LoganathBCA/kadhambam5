rules_version = '2';

// ──────────────────────────────────────────────────────────────
// Kadhambam – Firestore Security Rules
// Project: kadhambam4
// ──────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────

    // Is the caller signed in?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Is the caller the admin UID (from your .env VITE_ADMIN_UIDS)?
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.uid == 'jfHMcod747caz19hcK43b64hqkp2';
    }

    // Does the caller own this document (by userId field)?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────────────────────
    // /users/{userId}
    //   - Any authenticated user can read/write their own doc.
    //   - Admin can read all users.
    // ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /products/{productId}
    //   - Anyone (even unauthenticated) can read products.
    //   - Only admin can create / update / delete.
    // ─────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /categories/{categoryId}
    //   - Anyone can read categories.
    //   - Only admin can write.
    // ─────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /orders/{orderId}
    //   - Authenticated users can create orders (own orders only –
    //     the userId field in the document must match the caller).
    //   - A user can only read their own orders.
    //   - Admin can read / update / delete ALL orders.
    // ─────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Any signed-in user may place a new order for themselves
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;

      // Owner reads their own order; admin reads any order
      allow read:   if isAuthenticated() &&
                       (resource.data.userId == request.auth.uid || isAdmin());

      // Only admin may update order status / details
      allow update: if isAdmin();

      // Only admin may delete orders
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // /settings/{docId}
    //   - Anyone (even unauthenticated) can read settings like
    //     the offer bar so the marquee works on public pages.
    //   - Only admin can write settings.
    // ─────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // Deny everything else by default
    // ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
